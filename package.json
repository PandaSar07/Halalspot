{
    "name": "halalspot",
    "version": "1.0.0",
    "private": true,
    "description": "HalalSpot - Halal Restaurant Discovery Platform",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "type-check": "turbo run type-check",
        "clean": "turbo run clean && rm -rf node_modules",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
        "db:generate-types": "pnpm --filter @halalspot/shared-types generate-types"
    },
    "devDependencies": {
        "prettier": "^3.2.5",
        "turbo": "^1.12.4",
        "typescript": "^5.3.3"
    },
    "packageManager": "pnpm@8.15.1",
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    }
}